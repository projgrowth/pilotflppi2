{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main.tsx",
    "src/App.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "tailwind.config.ts",
    "postcss.config.js",
    "src/test/setup.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}"
  ],
  "ignore": [
    "playwright.config.ts",
    "playwright-fixture.ts",
    "src/integrations/supabase/types.ts",
    "supabase/functions/**"
  ],
  "ignoreDependencies": [
    "lovable-agent-playwright-config",
    "@playwright/test",
    "lovable-tagger",
    "tailwindcss-animate",
    "@tailwindcss/typography",
    "autoprefixer",
    "@testing-library/react",
    "jsdom"
  ]
}
